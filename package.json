{
  "name": "crew-chart-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "do:install": "npm install && npm --prefix server install",
    "do:build": "npm --prefix server run prisma:generate && npm run build && npm --prefix server run build",
    "do:start": "npm --prefix server run start",
    "server:dev": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "server:start": "npm --prefix server run start",
    "server:prisma:generate": "npm --prefix server run prisma:generate",
    "server:prisma:migrate": "npm --prefix server run prisma:migrate",
    "server:prisma:migrate:dev": "npm --prefix server run prisma:migrate:dev",
    "server:seed:admin": "npm --prefix server run seed:admin",
    "server:seed:cm-asia": "npm --prefix server run seed:cm-asia",
    "server:seed:cm-asia:built": "npm --prefix server run seed:cm-asia:built"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
