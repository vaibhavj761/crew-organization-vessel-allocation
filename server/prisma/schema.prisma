generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum UserStatus {
  PENDING_APPROVAL
  APPROVED_NEEDS_PASSWORD
  ACTIVE
  REJECTED
  DISABLED
}

enum PasswordTokenType {
  SET_PASSWORD
  RESET_PASSWORD
}

enum WorkflowRole {
  CREW_DIRECTOR
  OPERATIONS_MANAGER
  DEPUTY_MANAGER
  CREW_MANAGER
  ASSISTANT
}

enum VesselStatus {
  IN_MANAGEMENT
  UPCOMING
  OUT_OF_MANAGEMENT
}

enum ManagementType {
  FULL_MANAGED
  CREW_MANAGED
}

model User {
  id                   String          @id @default(cuid())
  name                 String
  email                String          @unique
  passwordHash         String?
  role                 Role            @default(VIEWER)
  status               UserStatus      @default(PENDING_APPROVAL)
  isActive             Boolean         @default(true)
  department           String?
  accessRequestMessage String?
  approvedByUserId     String?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  lastLoginAt          DateTime?
  permissionVersion    Int             @default(1)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  passwordTokens       PasswordToken[]
}

model PasswordToken {
  id        String            @id @default(cuid())
  userId    String
  tokenHash String
  type      PasswordTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([tokenHash])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  title         String
  effectiveDate  DateTime?
  footerText    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  people               Person[]
  crewDirectors        CrewDirector[]
  operationsManagers    OperationsManager[]
  deputyManagers        DeputyManager[]
  crewManagers          CrewManager[]
  operationsManagerReportingLines OperationsManagerReportingLine[]
  deputyManagerReportingLines DeputyManagerReportingLine[]
  crewManagerReportingLines CrewManagerReportingLine[]
  assistants            Assistant[]
  vessels               Vessel[]
}

model Person {
  id            String        @id @default(cuid())
  organizationId String
  name          String
  designation   String
  workflowRole  WorkflowRole
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  crewDirector CrewDirector?
  operationsManager OperationsManager?
  deputyManager DeputyManager?
  crewManager CrewManager?
  assistant Assistant?

  @@index([organizationId, workflowRole])
}

model CrewDirector {
  id             String   @id @default(cuid())
  organizationId String
  personId       String   @unique
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person             Person             @relation(fields: [personId], references: [id], onDelete: Cascade)
  operationsManagers OperationsManager[]
  reportingLines OperationsManagerReportingLine[]

  @@index([organizationId, sortOrder])
}

model OperationsManager {
  id                 String   @id @default(cuid())
  organizationId     String
  crewDirectorId     String
  personId           String   @unique
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  crewDirector  CrewDirector @relation(fields: [crewDirectorId], references: [id], onDelete: Restrict)
  person        Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  deputyManagers DeputyManager[]
  reportingLines OperationsManagerReportingLine[]
  deputyReportingLines DeputyManagerReportingLine[]

  @@index([organizationId, crewDirectorId, sortOrder])
}

model DeputyManager {
  id                  String   @id @default(cuid())
  organizationId      String
  operationsManagerId String
  personId            String   @unique
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operationsManager OperationsManager @relation(fields: [operationsManagerId], references: [id], onDelete: Restrict)
  person            Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  crewManagers      CrewManager[]
  reportingLines DeputyManagerReportingLine[]
  crewReportingLines CrewManagerReportingLine[]

  @@index([organizationId, operationsManagerId, sortOrder])
}

model CrewManager {
  id                  String   @id @default(cuid())
  organizationId      String
  deputyManagerId     String
  personId            String   @unique
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deputyManager     DeputyManager     @relation(fields: [deputyManagerId], references: [id], onDelete: Restrict)
  person            Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  assistants        Assistant[]
  vesselAllocations VesselAllocation[]
  reportingLines CrewManagerReportingLine[]

  @@index([organizationId, deputyManagerId, sortOrder])
}

model OperationsManagerReportingLine {
  id                  String   @id @default(cuid())
  organizationId      String
  operationsManagerId String
  crewDirectorId      String
  isPrimary           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operationsManager OperationsManager @relation(fields: [operationsManagerId], references: [id], onDelete: Cascade)
  crewDirector     CrewDirector     @relation(fields: [crewDirectorId], references: [id], onDelete: Cascade)
  deputyReportingLines DeputyManagerReportingLine[]

  @@unique([operationsManagerId, crewDirectorId])
  @@index([organizationId, crewDirectorId])
}

model DeputyManagerReportingLine {
  id                  String   @id @default(cuid())
  organizationId      String
  deputyManagerId     String
  operationsManagerId String
  operationsManagerReportingLineId String
  isPrimary           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deputyManager     DeputyManager     @relation(fields: [deputyManagerId], references: [id], onDelete: Cascade)
  operationsManager OperationsManager @relation(fields: [operationsManagerId], references: [id], onDelete: Cascade)
  operationsManagerReportingLine OperationsManagerReportingLine @relation(fields: [operationsManagerReportingLineId], references: [id], onDelete: Cascade)
  crewReportingLines CrewManagerReportingLine[]

  @@unique([deputyManagerId, operationsManagerReportingLineId])
  @@index([organizationId, operationsManagerId])
  @@index([operationsManagerReportingLineId])
}

model CrewManagerReportingLine {
  id              String   @id @default(cuid())
  organizationId  String
  crewManagerId   String
  deputyManagerId String
  deputyManagerReportingLineId String
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  crewManager  CrewManager  @relation(fields: [crewManagerId], references: [id], onDelete: Cascade)
  deputyManager DeputyManager @relation(fields: [deputyManagerId], references: [id], onDelete: Cascade)
  deputyManagerReportingLine DeputyManagerReportingLine @relation(fields: [deputyManagerReportingLineId], references: [id], onDelete: Cascade)
  vesselAllocations VesselAllocation[]

  @@unique([crewManagerId, deputyManagerReportingLineId])
  @@index([organizationId, deputyManagerId])
  @@index([deputyManagerReportingLineId])
}

model Assistant {
  id             String   @id @default(cuid())
  organizationId String
  crewManagerId  String
  personId       String   @unique
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  crewManager  CrewManager  @relation(fields: [crewManagerId], references: [id], onDelete: Restrict)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  vesselAllocations VesselAllocation[]

  @@index([organizationId, crewManagerId, sortOrder])
}

model Vessel {
  id                   String         @id @default(cuid())
  organizationId       String
  name                 String
  vesselType           String?
  vesselDoc            String?
  deadweightTonnage    String?
  ownerPool            String?
  ownerName            String?
  marineSuperintendent String?
  vesselManager        String?
  takeoverDate         DateTime?
  handoverDate         DateTime?
  vesselStatus         VesselStatus
  managementType       ManagementType
  notes                String?
  sortOrder            Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vesselAllocations VesselAllocation[]

  @@index([organizationId, sortOrder])
  @@index([organizationId, vesselStatus, managementType])
}

model VesselAllocation {
  id                   String   @id @default(cuid())
  vesselId             String   @unique
  crewManagerId        String
  crewManagerReportingLineId String
  assignedAssistantId  String?
  allocatedAt          DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  vessel           Vessel        @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  crewManager      CrewManager    @relation(fields: [crewManagerId], references: [id], onDelete: Restrict)
  crewManagerReportingLine CrewManagerReportingLine @relation(fields: [crewManagerReportingLineId], references: [id], onDelete: Restrict)
  assignedAssistant Assistant?    @relation(fields: [assignedAssistantId], references: [id], onDelete: SetNull)

  @@index([crewManagerId])
  @@index([crewManagerReportingLineId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}
